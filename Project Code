CREATE DATABASE chicago_traffic_citations;

CREATE TABLE fines (
    fine_level TINYINT NOT NULL,               -- 1 or 2
    fine_amount DECIMAL(10,2) NOT NULL,       -- 0-600
    PRIMARY KEY (fine_level, fine_amount)
);

CREATE TABLE violation_types (
	violation_type_id INT PRIMARY KEY AUTO_INCREMENT,
    violation_code VARCHAR(20),
    description VARCHAR(100)
);

CREATE TABLE vehicle_information (
    license_plate_type VARCHAR(50) NOT NULL,
    vehicle_make VARCHAR(50) NOT NULL,
    PRIMARY KEY (license_plate_type, vehicle_make) 
);
