CREATE DATABASE chicago_traffic_citations;
USE chicago_traffic_citations;

CREATE TABLE fines (
    fine_id INT AUTO_INCREMENT PRIMARY KEY,      
    fine_level TINYINT NOT NULL,                 
    fine_amount DECIMAL(10,2) NOT NULL CHECK 
);

CREATE TABLE violation_types (
	violation_type_id INT PRIMARY KEY AUTO_INCREMENT,
    violation_code VARCHAR(20),
    description VARCHAR(100)
);

CREATE TABLE vehicle_information (
    vehicle_id INT AUTO_INCREMENT PRIMARY KEY,  
    license_plate_type VARCHAR(50) NOT NULL,     
    vehicle_make VARCHAR(50) NOT NULL           
);

CREATE Table violations (
	violation_id INT PRIMARY KEY AUTO_INCREMENT,
    violation_date DATE NOT NULL,
    
    violation_type_id INT NOT NULL,
    fine_id INT,
    vehicle_id INT,
    -- location_id INT,
    -- officer_id INT,
    
    time_of_day VARCHAR(20),
    issued_by VARCHAR(20), -- camera or officer
    
    FOREIGN KEY (violation_type_id)
    REFERENCES violation_types(violation_type_id),
    
    FOREIGN KEY (fine_id)
    REFERENCES fines(fine_id),
    
    FOREIGN KEY (vehicle_id)
    REFERENCES vehicle_information(vehicle_id)
);

CREATE TABLE payments (
    payment_id INT AUTO_INCREMENT PRIMARY KEY,     
    ticket_number BIGINT NOT NULL,                  
    current_amount_due DECIMAL(10,2) NOT NULL,     
    total_payments DECIMAL(10,2) NOT NULL,         
    payment_status VARCHAR(10) NOT NULL,           
    FOREIGN KEY (ticket_number) REFERENCES tickets(ticket_number)
);
